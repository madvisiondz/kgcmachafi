# --- Dependencies & build output ---
node_modules/
**/node_modules/
# frontend/dist is tracked so backups include the built SPA (regenerate with: cd frontend && npm run build)
frontend/dist-ssr/

# --- Env & secrets (never commit real credentials) ---
.env
.env.*
!.env.example

# --- Logs ---
logs/
*.log
npm-debug.log*
yarn-debug.log*
pnpm-debug.log*

# --- OS / editor ---
.DS_Store
Thumbs.db
.idea/
.vscode/*
!.vscode/extensions.json
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# --- PHP / deploy (existing project rules) ---
admin-config.php
uploads/*
!uploads/.gitkeep

# Local MariaDB data (created by tools/start-mysql.ps1)
.tools/mysql-data/

# --- Accidental / non-project paths (do not commit) ---
WindowsPowerShell/
WPSDrive/
office6/
