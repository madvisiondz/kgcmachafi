# Copy to `.env` or `.env.local` for local overrides (never commit real secrets).
# See `NEXT_STEPS_PRODUCTION.md` Phase A and `ARCHITECTURE_PRODUCTION_READINESS.md`.

# Logical environment label (optional; defaults to Vite MODE).
# VITE_APP_ENV=development

# Public marketing / canonical URL (OG, absolute links later).
VITE_PUBLIC_SITE_URL=https://kgc-machafi.net

# API prefix or full origin for the PHP `api/` JSON surface (future `services/` client).
# Same-host deploy: relative path is fine.
VITE_API_BASE_URL=/api

# Set to "true" to load `/public/news.php` (PHP + MySQL on GoDaddy) instead of demo mocks only.
# VITE_NEWS_API=false

# Set to "true" to load `/public/pharmacies.php` instead of demo directory mocks only.
# VITE_PHARMACIES_API=false

# Optional: milliseconds to hold list loaders (preview skeleton / slow-network UX in dev).
# VITE_LIST_BOOTSTRAP_MS=0

# Optional: default HLS or stream URL for TV player when backend is ready.
# VITE_TV_STREAM_URL=

# Set to "true" when HLS player is implemented (Phase E).
VITE_FEATURE_TV_HLS=false
