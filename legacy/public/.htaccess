## KGC Machafi (Production) — Apache config
## This file is copied to `dist/.htaccess` by Vite (public/ → dist/)

<IfModule mod_rewrite.c>
  RewriteEngine On

  # Never rewrite real asset paths
  RewriteRule ^assets/ - [L]

  # If the request is for an existing file/folder, serve it.
  RewriteCond %{REQUEST_FILENAME} -f [OR]
  RewriteCond %{REQUEST_FILENAME} -d
  RewriteRule ^ - [L]

  # If a request looks like a static file but doesn't exist, return 404 (avoid serving index.html as JS/CSS)
  RewriteCond %{REQUEST_URI} \.(?:css|js|mjs|map|json|png|jpg|jpeg|gif|svg|webp|ico|woff2?)$ [NC]
  RewriteRule ^ - [R=404,L]

  # SPA routing: everything else → index.html
  RewriteRule ^ index.html [L]
</IfModule>

<IfModule mod_headers.c>
  # Basic security headers
  Header always set X-Content-Type-Options "nosniff"
  Header always set X-Frame-Options "SAMEORIGIN"
  Header always set Referrer-Policy "strict-origin-when-cross-origin"
  Header always set Permissions-Policy "geolocation=(), microphone=(), camera=()"

  # Cache policy:
  # - hashed assets: long cache
  # - HTML entry: no cache (so deploys update instantly)
  <FilesMatch "\.(css|js|mjs|woff2|png|jpg|jpeg|gif|svg|webp|ico)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>
  <FilesMatch "^(index\.html)$">
    Header set Cache-Control "no-store, no-cache, must-revalidate, max-age=0"
  </FilesMatch>
</IfModule>

<IfModule mod_mime.c>
  AddType application/javascript .js .mjs
  AddType text/css .css
</IfModule>

<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/plain text/css application/javascript application/json image/svg+xml
</IfModule>

